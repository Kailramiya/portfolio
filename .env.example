# Server-side email (used by api/contact.js)
# IMPORTANT: these are NOT VITE_ variables; they must be available to the serverless function.

# SMTP provider settings (examples: Gmail SMTP, SendGrid SMTP, Brevo, Mailgun SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password

# Envelope addresses
# SMTP_FROM must typically be an address allowed by your SMTP provider.
SMTP_FROM=officialamankundu@gmail.com
CONTACT_TO=officialamankundu@gmail.com

# Optional
SITE_NAME=Aman Kumar Portfolio
AUTO_REPLY_ENABLED=true
